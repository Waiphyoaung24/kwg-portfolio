---
import Layout from '@layouts/Layout.astro';
---

<Layout>
  <main>
    <iframe
      src="/constellation/index.html"
      title="My Portfolio — Constellation"
      loading="lazy"
      allow="fullscreen"
    ></iframe>
  </main>
</Layout>

<style lang="scss">
  main {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
</style>
